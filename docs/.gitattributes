# =============================================================================
# EduMyles — docs/.gitattributes
#
# export-ignore prevents these files from being included when someone
# downloads a zip/tarball of the repo or forks it.
# PDFs are also excluded from git tracking via .gitignore.
# =============================================================================

# Exclude all PDFs from git archive exports and forks
*.pdf   export-ignore
*.PDF   export-ignore

# Exclude markdown docs from exports (internal guides)
Agent_Build_Prompt.md   export-ignore
Agent_Action_Plan.md    export-ignore
