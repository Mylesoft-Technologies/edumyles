# =============================================================================
# EduMyles — .gitignore
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────────────────────────
.next/
dist/
build/
out/
.expo/

# ── Convex / Backend ──────────────────────────────────────────────────────────
.convex/
backend/_generated/         # Auto-generated by Convex CLI — never commit

# ── Environment & Secrets ─────────────────────────────────────────────────────
# NEVER commit any .env files — use GitHub org secrets instead
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
.env.test

# ── Documentation — PDFs are stored externally, not in git ───────────────────
# Docs are shared via secure link, not committed to protect IP
docs/*.pdf
docs/**/*.pdf
*.pdf

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/
cypress/screenshots/
cypress/videos/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Mobile / React Native ─────────────────────────────────────────────────────
mobile/.expo/
mobile/ios/Pods/
mobile/android/.gradle/
mobile/android/build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
.turbo/
.cache/
